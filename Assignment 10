from temperature import celsius_to_fahrenheit as ctf
from temperature import fahrenheit_to_celsius as ftc
from temperature import celsius_to_kelvin as ctk

def menu():
    print("\n===== TEMPERATURE CONVERTER =====")
    print("1. Celsius to Fahrenheit")
    print("2. Fahrenheit to Celsius")
    print("3. Celsius to Kelvin")
    print("4. Exit")

while True:
    menu()
    try:
        choice = int(input("Enter choice: "))

        if choice == 1:
            c = float(input("Enter Celsius: "))
            print("Fahrenheit:", round(ctf.convert(c), 2))

        elif choice == 2:
            f = float(input("Enter Fahrenheit: "))
            print("Celsius:", round(ftc.convert(f), 2))

        elif choice == 3:
            c = float(input("Enter Celsius: "))
            print("Kelvin:", round(ctk.convert(c), 2))

        elif choice == 4:
            print("Program Ended")
            break

        else:
            print("Invalid Choice!")

    except ValueError:
        print("Please enter valid numeric input!")
